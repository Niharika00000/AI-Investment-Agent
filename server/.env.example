# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/investdb"

# LLM Provider — choose: "google" | "openai" | "anthropic"
LLM_PROVIDER=google

# Google Gemini — free key at https://aistudio.google.com
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key-here"
GOOGLE_MODEL=gemini-1.5-flash

# OpenAI (optional — set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=""
OPENAI_MODEL=gpt-4o

# Auth
JWT_SECRET="change-this-to-a-strong-secret"

# Optional external data APIs (improves research quality if provided)
NEWS_API_KEY=""
FINNHUB_API_KEY=""
ALPHA_VANTAGE_API_KEY=""

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Set to "true" for instant mock data (no API calls — useful for demos/CI)
MOCK_MODE=false
