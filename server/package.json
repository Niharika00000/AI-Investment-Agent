  "main": "dist/index.js",
  "scripts": {
    "predev": "node scripts/kill-port.cjs",
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "prestart": "node scripts/kill-port.cjs",
